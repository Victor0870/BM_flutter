rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function để kiểm tra user đã đăng nhập
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function để kiểm tra user có UID khớp với document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin: có document trong admins/{uid} với field admin == true (tạo thủ công trong Console)
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.admin == true;
    }

    // Collection admins: mỗi user chỉ đọc được document của chính mình; không cho client ghi (chỉ Console/Admin SDK)
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    // Rules cho collection shops
    // Owner đọc/ghi shop của mình; Admin đọc và cập nhật mọi shop (để nâng cấp PRO)
    match /shops/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isOwner(userId);

      // Rules cho subcollection products của shop
      match /products/{productId} {
        // Chỉ owner của shop mới có quyền đọc/ghi products
        allow read, write: if isOwner(userId);
      }

      // Rules cho subcollection sales của shop
      match /sales/{saleId} {
        // Chỉ owner của shop mới có quyền đọc/ghi sales
        allow read, write: if isOwner(userId);
      }

      // Rules cho subcollection purchases của shop
      match /purchases/{purchaseId} {
        // Chỉ owner của shop mới có quyền đọc/ghi purchases
        allow read, write: if isOwner(userId);
      }

      // Rules cho subcollection categories của shop
      match /categories/{categoryId} {
        // Chỉ owner của shop mới có quyền đọc/ghi categories
        allow read, write: if isOwner(userId);
      }

      // Rules cho subcollection branches của shop (chi nhánh)
      match /branches/{branchId} {
        allow read, write: if isOwner(userId);
      }

      // Rules cho subcollection customers của shop (danh sách KH, chi tiết, popup sửa)
      match /customers/{customerId} {
        allow read, write: if isOwner(userId);
      }

      // Rules cho subcollection suppliers của shop (nhà cung cấp)
      match /suppliers/{supplierId} {
        allow read, write: if isOwner(userId);
      }

      // Rules cho subcollection customer_groups của shop (nhóm KH, lọc, cột hiển thị)
      match /customer_groups/{groupId} {
        allow read, write: if isOwner(userId);
      }

      // Rules cho subcollection employee_groups của shop
      match /employee_groups/{groupId} {
        allow read, write: if isOwner(userId);
      }

      // Metadata file Excel KiotViet (Data base danganh.xlsx) — chỉ owner, dùng khi syncWithKiotViet
      match /kiotVietFile/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Nội dung Excel KiotViet đã parse: meta + từng sheet (doc) + rows (subcollection) — chỉ owner
      match /kiotVietData/{docId} {
        allow read, write: if isOwner(userId);
        match /rows/{rowId} {
          allow read, write: if isOwner(userId);
        }
      }
    }

    // Collection users (root): dùng cho đăng nhập, shopId, role, isApproved (pending staff)
    // - User đọc/cập nhật chính mình; owner shop đọc/cập nhật nhân viên thuộc shop; Admin đọc tất cả (để thống kê)
    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || resource.data.shopId == request.auth.uid
        || isAdmin()
      );
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        request.auth.uid == userId
        || resource.data.shopId == request.auth.uid
      );
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Collection notifications (root): owner hoặc staff của shop có thể đọc
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (
        resource.data.shopId == request.auth.uid
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == resource.data.shopId
      );
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        resource.data.shopId == request.auth.uid
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == resource.data.shopId
      );
    }

    // system_settings: cấu hình toàn hệ thống (vd. isTest cho AdMob / eInvoice)
    // Mọi user đã đăng nhập được đọc; chỉ admin (sau này) mới ghi nếu cần
    match /system_settings/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // global_parts_catalog: danh mục phụ tùng (upload 1 lần rồi xóa tính năng)
    // Sau khi sửa file này, nhớ chạy: firebase deploy --only firestore:rules
    match /global_parts_catalog/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // feedback: góp ý từ user (root collection). User tạo và đọc theo shopId; Admin đọc tất cả và cập nhật (phản hồi).
    match /feedback/{feedbackId} {
      allow read: if isSignedIn() && (
        resource.data.shopId == request.auth.uid
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.shopId == resource.data.shopId
        || isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.shopId is string && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Deny tất cả các truy cập khác
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

